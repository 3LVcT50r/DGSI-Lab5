#!/usr/bin/env bash
# Wrapper for running the factory-app CLI from the workspace root on Linux/macOS.
# It changes into factory-app and sets PYTHONPATH so python can locate src.
# Uses the project venv if present.

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT/factory-app" || exit 1
PY="$ROOT/venv/bin/python"
[ -x "$PY" ] || PY="python"
PYTHONPATH="." "$PY" -m src.cli "$@"
